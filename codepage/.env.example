# ===========================================
# CodePage 环境变量配置
# 复制本文件为 .env 并填入真实值
# ===========================================

# ---- 服务配置 ----
PORT=3000                          # 服务端口
NODE_ENV=development                # 运行环境: development | production

# ---- LLM 大模型配置 ----
# 以下为 DeepSeek 示例（默认）
LLM_PROVIDER=deepseek               # 供应商名称（仅用于标识）
LLM_BASE_URL=https://api.deepseek.com
LLM_API_KEY=sk-your-api-key-here    # 替换为真实 API Key
LLM_MODEL=deepseek-chat             # 模型名

# 可选：轻量模型（用于简单任务）
LLM_MINOR_MODEL=deepseek-chat

# ---- Ollama 本地模型配置示例 ----
# 将上方 LLM_* 注释掉，取消下方注释即可切换到 Ollama
# LLM_PROVIDER=ollama
# LLM_BASE_URL=http://localhost:11434
# LLM_API_KEY=ollama                # Ollama 不需要真实 Key，任意值即可
# LLM_MODEL=llama3.2

# ---- 历史记录 ----
HISTORY_MAX=200                     # 生成历史最大存储条数（可自定义）
