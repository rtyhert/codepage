generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./data/data.db"
}

model Project {
  id        String   @id @default(cuid())
  name      String
  prompt    String
  pages     Page[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Page {
  id        String   @id @default(cuid())
  projectId String
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  name      String
  format    String   @default("html")
  code      String
  prompt    String
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model History {
  id        String   @id @default(cuid())
  prompt    String
  code      String
  format    String   @default("html")
  tagHints  String?
  createdAt DateTime @default(now())
}

model AgentRun {
  id          String     @id @default(cuid())
  name        String
  requirement String
  status      String     @default("pending")
  projectId   String?    @default("")
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
  tasks       AgentTask[]
  result      String?
}

model AgentTask {
  id          String   @id @default(cuid())
  agentRunId  String
  agentRun    AgentRun @relation(fields: [agentRunId], references: [id], onDelete: Cascade)
  agentType   String
  name        String
  description String
  input       String?
  output      String?
  status      String   @default("pending")
  error       String?
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}
